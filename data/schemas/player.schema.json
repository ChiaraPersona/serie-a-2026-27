{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Serie A player",
  "type": "object",
  "required": [
    "id",
    "name",
    "currentTeam",
    "currentSeason",
    "role",
    "status",
    "previousSeason",
    "sources",
    "dataQuality"
  ],
  "properties": {
    "status": {
      "enum": [
        "confermato",
        "nuovo acquisto",
        "prestito",
        "rientro dal prestito",
        "primavera",
        "da verificare"
      ]
    },
    "previousSeason": {
      "type": "object",
      "required": [
        "season",
        "entries",
        "totals",
        "totalsByCompetition"
      ]
    }
  }
}
