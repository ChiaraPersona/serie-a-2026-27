{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Serie A team",
  "type": "object",
  "required": [
    "id",
    "currentSeason",
    "city",
    "stadium",
    "coach",
    "previousSeason",
    "teamStats",
    "squad",
    "sources",
    "lastUpdated"
  ],
  "properties": {
    "city": {
      "type": "string",
      "minLength": 1
    },
    "stadium": {
      "type": "string",
      "minLength": 1
    },
    "coach": {
      "type": "string",
      "minLength": 1
    },
    "squad": {
      "type": "array",
      "items": {
        "$ref": "player.schema.json"
      }
    }
  }
}
